{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Frontmatter Schema V2",
  "description": "Validation schema for SKILL.md frontmatter YAML (V2 with staleness metadata)",
  "type": "object",
  "required": ["name", "description", "version"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Kebab-case identifier"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Visible by Cascade for auto-invocation"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "author": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "category": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": ["workspace", "global", "system"]
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "triggers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "description": { "type": "string" },
          "default": {},
          "enum": { "type": "array" }
        },
        "required": ["type", "description"]
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["type", "description"]
      }
    },
    "auto_invoke": {
      "type": "boolean"
    },
    "confidence_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rag_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mcp_servers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "description": "V2 staleness metadata",
      "properties": {
        "created": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Creation date (YYYY-MM-DD)"
        },
        "last_reviewed": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Last review date (YYYY-MM-DD)"
        },
        "review_interval_days": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365,
          "description": "Review interval in days"
        },
        "generator": {
          "type": "string",
          "description": "Name of the generator that created this file"
        },
        "generator_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Version of the generator"
        }
      },
      "required": ["created", "last_reviewed", "review_interval_days"]
    }
  }
}
